  "keyFeatures": [
    "Pure Java Type 4 JDBC driver — no native libraries required",
    "Full SSL/TLS support with configurable validation modes (disable, allow, prefer, require, verify-ca, verify-full)",
    "Server-side prepared statements with automatic threshold-based activation",
    "Logical and physical replication streaming API",
    "Connection pooling via PGSimpleDataSource and PGConnectionPoolDataSource",
    "XA distributed transaction support via PGXADataSource",
    "Binary data transfer for improved performance",
    "COPY protocol support for bulk data import/export",
    "Asynchronous LISTEN/NOTIFY support",
    "Java 8 Date and Time API support (JSR-310)",
    "GSSAPI/Kerberos and SSPI authentication",
    "Multi-host connection failover and load balancing",
    "Adaptive fetch size for ResultSets",
    "PostgreSQL-specific geometry types and large objects"
  ],
  "publicApiSurface": [
    "org.postgresql.Driver (java.sql.Driver)",
    "org.postgresql.ds.PGSimpleDataSource (javax.sql.DataSource)",
    "org.postgresql.ds.PGConnectionPoolDataSource (javax.sql.ConnectionPoolDataSource)",
    "org.postgresql.xa.PGXADataSource (javax.sql.XADataSource)",
    "org.postgresql.PGConnection (PostgreSQL-specific connection extensions)",
    "org.postgresql.PGStatement (PostgreSQL-specific statement extensions)",
    "org.postgresql.copy.CopyManager (COPY protocol support)",
    "org.postgresql.replication.PGReplicationConnection (Replication API)",
    "org.postgresql.replication.PGReplicationStream (Streaming replication)",
    "org.postgresql.largeobject.LargeObjectManager (Large Object API)",
    "org.postgresql.geometric.* (Geometry types: PGpoint, PGcircle, PGline, etc.)",
    "org.postgresql.PGProperty (Connection property constants)",
    "org.postgresql.util.PGobject (Custom type base class)",
    "DriverManager.getConnection(\"jdbc:postgresql://host:port/database\", props)"
  ]
}
